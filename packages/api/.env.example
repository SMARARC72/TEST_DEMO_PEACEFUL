# ─── Peacefull API — Environment Variables ───────────────────────────
# Copy to .env and fill in values. All variables listed here are referenced
# by production code. See UGO-7 in 3.4.26PT1.md for rotation policy.
# ─────────────────────────────────────────────────────────────────────

# Database — Neon Serverless Postgres
# Pooled connection (via Neon connection pooler, port 5432)
DATABASE_URL=postgresql://peacefull:peacefull@localhost:5432/peacefull?schema=public
# Direct connection for migrations (non-pooled, port 5432 for local; use Neon direct URL in prod)
DIRECT_DATABASE_URL=postgresql://peacefull:peacefull@localhost:5432/peacefull?schema=public

# Redis (BullMQ job queue, session cache)
REDIS_URL=redis://localhost:6379

# Anthropic (Claude) — AI features
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT — min 32 chars, rotate every 90 days in production
JWT_SECRET=your-jwt-secret-min-32-chars-here-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-here-change-in-production

# Auth0 (optional for local dev)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=peacefull-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SES (email notifications)
SES_FROM_EMAIL=noreply@peacefull.cloud

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Comma-separated origins by environment (wildcards are not allowed in staging/production).
# Development example:
# CORS_ORIGIN=http://localhost:5173,http://localhost:4173
# Staging example:
# CORS_ORIGIN=https://staging.peacefull.cloud,https://staging-admin.peacefull.cloud
# Production example:
# CORS_ORIGIN=https://peacefull.cloud,https://app.peacefull.cloud
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
LOG_LEVEL=debug

# Sentry (error tracking — required in production)
SENTRY_DSN=

# Encryption (required in production — AES-256 key for PII at rest)
ENCRYPTION_KEY=

# ⚠️  PRODUCTION SAFETY: VITE_DEMO_MODE must NOT be set in production.
# It enables demo mock data that bypasses real API calls.
# VITE_DEMO_MODE=true  # ONLY for local development
