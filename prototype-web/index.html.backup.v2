  <!-- STORY MODE -->
  <div id="story-mode" class="screen min-h-screen bg-slate-100">
    <div class="glass-dark p-4 sticky top-0 z-10">
      <div class="flex items-center justify-between max-w-7xl mx-auto">
        <div class="flex items-center gap-4">
          <button onclick="showScreen('landing')" class="text-slate-400 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <h1 class="font-bold text-white">Story Mode: Sarah's Journey</h1>
        </div>
        <button onclick="resetStory()" class="px-4 py-2 bg-slate-700 text-white rounded-lg text-sm hover:bg-slate-600">Restart Story</button>
      </div>
    </div>
    <div class="p-6 max-w-6xl mx-auto">
      <!-- Timeline -->
      <div class="flex justify-center gap-2 mb-8">
        <div id="story-dot-1" class="w-8 h-8 rounded-full bg-teal-500 flex items-center justify-center text-white text-sm font-bold active">1</div>
        <div class="w-16 h-0.5 bg-slate-300 self-center"></div>
        <div id="story-dot-2" class="w-8 h-8 rounded-full bg-slate-300 flex items-center justify-center text-slate-600 text-sm font-bold">2</div>
        <div class="w-16 h-0.5 bg-slate-300 self-center"></div>
        <div id="story-dot-3" class="w-8 h-8 rounded-full bg-slate-300 flex items-center justify-center text-slate-600 text-sm font-bold">3</div>
        <div class="w-16 h-0.5 bg-slate-300 self-center"></div>
        <div id="story-dot-4" class="w-8 h-8 rounded-full bg-slate-300 flex items-center justify-center text-slate-600 text-sm font-bold">4</div>
        <div class="w-16 h-0.5 bg-slate-300 self-center"></div>
        <div id="story-dot-5" class="w-8 h-8 rounded-full bg-slate-300 flex items-center justify-center text-slate-600 text-sm font-bold">5</div>
      </div>
      <!-- Story Steps -->
      <div class="relative">
        <!-- Step 1: The Struggle -->
        <div id="story-step-1" class="story-step">
          <div class="story-mode-container">
            <div class="bg-white rounded-2xl shadow-sm p-6">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-16 h-16 bg-slate-200 rounded-full flex items-center justify-center">
                  <span class="text-2xl">👤</span>
                </div>
                <div>
                  <h3 class="font-bold text-slate-800">Meet Sarah</h3>
                  <p class="text-slate-500">34, living with anxiety</p>
                </div>
              </div>
              <p class="text-slate-600 mb-4">Sarah has been struggling with anxiety between her weekly therapy sessions. She often feels overwhelmed but doesn't know when to reach out.</p>
              <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
                <p class="text-amber-800 text-sm"><strong>The Problem:</strong> 68% of mental health crises happen between sessions. Without continuous monitoring, warning signs are missed.</p>
              </div>
            </div>
            <div class="bg-gradient-to-br from-teal-500 to-teal-600 rounded-2xl shadow-sm p-6 text-white">
              <h3 class="font-bold mb-4">The Opportunity</h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span>24/7 patient monitoring</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span>AI-powered risk detection</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span>Clinician-supervised alerts</span>
                </li>
              </ul>
            </div>
          </div>
          <div class="flex justify-end mt-6">
            <button onclick="nextStoryStep()" class="px-6 py-3 bg-teal-500 text-white rounded-xl font-semibold hover:bg-teal-600 transition-colors">Next: Sarah's First Check-in →</button>
          </div>
        </div>
        <!-- Step 2: First Check-in -->
        <div id="story-step-2" class="story-step hidden">
          <div class="story-mode-container">
            <div class="bg-white rounded-2xl shadow-sm p-6">
              <h3 class="font-bold text-slate-800 mb-4">📱 Sarah's Daily Check-in</h3>
              <div class="space-y-4">
                <div>
                  <p class="text-sm text-slate-500 mb-2">Mood Rating: 2/5</p>
                  <div class="h-2 bg-slate-100 rounded-full">
                    <div class="h-full bg-red-500 rounded-full" style="width: 40%"></div>
                  </div>
                </div>
                <div>
                  <p class="text-sm text-slate-500 mb-2">Stress Level: 4/5</p>
                  <div class="h-2 bg-slate-100 rounded-full">
                    <div class="h-full bg-red-500 rounded-full" style="width: 80%"></div>
                  </div>
                </div>
                <div class="bg-slate-50 rounded-lg p-4">
                  <p class="text-sm text-slate-600">"Work has been really overwhelming. I'm having trouble sleeping and my mind won't stop racing."</p>
                </div>
              </div>
            </div>
            <div class="bg-white rounded-2xl shadow-sm p-6 border-2 border-teal-200">
              <h3 class="font-bold text-teal-700 mb-4">🤖 AI Analysis</h3>
              <div class="space-y-3">
                <div class="flex items-center gap-2">
                  <span class="text-sm text-slate-600">Sentiment:</span>
                  <span class="px-2 py-1 bg-red-100 text-red-700 rounded text-sm font-medium">Negative (78%)</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-sm text-slate-600">Risk Level:</span>
                  <span class="px-2 py-1 bg-amber-100 text-amber-700 rounded text-sm font-medium">T1 - Monitor</span>
                </div>
                <div class="bg-teal-50 rounded-lg p-3">
                  <p class="text-sm text-teal-700"><strong>Keywords detected:</strong> "overwhelming", "trouble sleeping", "mind racing"</p>
                </div>
              </div>
            </div>
          </div>
          <div class="flex justify-between mt-6">
            <button onclick="prevStoryStep()" class="px-6 py-3 bg-slate-200 text-slate-700 rounded-xl font-semibold hover:bg-slate-300 transition-colors">← Back</button>
            <button onclick="nextStoryStep()" class="px-6 py-3 bg-teal-500 text-white rounded-xl font-semibold hover:bg-teal-600 transition-colors">Next: Escalation →</button>
          </div>
        </div>
        <!-- Step 3: Crisis Detection -->
        <div id="story-step-3" class="story-step hidden">
          <div class="bg-red-50 border-2 border-red-200 rounded-2xl p-6 mb-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 bg-red-500 rounded-full flex items-center justify-center animate-pulse">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-red-700 text-xl">T2 Alert Triggered</h3>
                <p class="text-red-600">High-risk pattern detected</p>
              </div>
            </div>
            <p class="text-red-800 mb-4">Three days later, Sarah's journal entry contains concerning language. The AI immediately flags this as a T2 alert.</p>
            <div class="bg-white rounded-lg p-4">
              <p class="text-slate-700 italic">"I don't see the point anymore. Everything feels hopeless and I don't know if I can keep going..."</p>
            </div>
          </div>
          <div class="story-mode-container">
            <div class="bg-white rounded-2xl shadow-sm p-6">
              <h3 class="font-bold text-slate-800 mb-4">⚡ Real-time Alert</h3>
              <div class="space-y-3">
