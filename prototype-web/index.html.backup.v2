              </div>
              <div class="p-4 hover:bg-slate-50">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-sm text-slate-500">Yesterday, 8:00 PM</span>
                  <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded">Journal</span>
                </div>
                <p class="text-slate-700">Had a difficult day at work. The new project is overwhelming and I'm struggling to keep up with deadlines.</p>
              </div>
              <div class="p-4 hover:bg-slate-50">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-sm text-slate-500">Feb 23, 7:30 PM</span>
                  <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded">Journal</span>
                </div>
                <p class="text-slate-700">Feeling a bit better today. Went for a walk and it helped clear my mind.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="space-y-6">
          <div class="bg-white rounded-2xl shadow-sm p-6">
            <h2 class="font-semibold text-slate-800 mb-4">Patient Info</h2>
            <div class="space-y-3">
              <div>
                <p class="text-sm text-slate-500">Age</p>
                <p class="font-medium text-slate-800">34 years old</p>
              </div>
              <div>
                <p class="text-sm text-slate-500">Diagnosis</p>
                <p class="font-medium text-slate-800">Major Depressive Disorder</p>
              </div>
              <div>
                <p class="text-sm text-slate-500">Medication</p>
                <p class="font-medium text-slate-800">Sertraline 50mg</p>
              </div>
              <div>
                <p class="text-sm text-slate-500">Next Appointment</p>
                <p class="font-medium text-slate-800">Tomorrow, 2:00 PM</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-2xl shadow-sm p-6">
            <h2 class="font-semibold text-slate-800 mb-4">Care Team Notes</h2>
            <div class="bg-slate-50 rounded-xl p-4 mb-3">
              <p class="text-sm text-slate-600 mb-2">Last session: Patient reported increased stress at work. Discussed coping strategies.</p>
              <p class="text-xs text-slate-400">— Dr. Sarah Chen, Feb 20</p>
            </div>
            <button onclick="showToast('Note added')" class="w-full py-2 border-2 border-dashed border-slate-300 rounded-xl text-slate-500 text-sm font-medium hover:border-coral-500 hover:text-coral-500 transition-colors">+ Add Note</button>
          </div>
          <div class="bg-gradient-to-br from-teal-500 to-teal-600 rounded-2xl shadow-sm p-6 text-white">
            <h2 class="font-semibold mb-2">AI Insights</h2>
            <p class="text-sm text-teal-100 mb-4">Based on recent entries, patient may benefit from:</p>
            <ul class="text-sm space-y-2">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Increased session frequency
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                CBT for negative thoughts
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Sleep hygiene review
              </li>
            </ul>
            <div class="mt-4 pt-4 border-t border-teal-400">
              <p class="text-xs text-teal-200">These are AI-generated suggestions. Clinical judgment required.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Screen navigation
    function showScreen(screenId) {
      document.querySelectorAll('.screen').forEach(s => {
        s.classList.remove('active');
        setTimeout(() => { if (!s.classList.contains('active')) s.style.display = 'none'; }, 300);
      });
      const target = document.getElementById(screenId);
      target.style.display = 'block';
      setTimeout(() => target.classList.add('active'), 10);
      window.scrollTo(0, 0);
    }

    // Consent checkboxes
    function checkConsents() {
      const checks = document.querySelectorAll('.consent-check');
      const allChecked = Array.from(checks).every(c => c.checked);
      const btn = document.getElementById('consent-btn');
      if (allChecked) {
        btn.disabled = false;
        btn.classList.remove('bg-slate-300', 'text-slate-500');
        btn.classList.add('btn-primary', 'text-white');
      } else {
        btn.disabled = true;
        btn.classList.add('bg-slate-300', 'text-slate-500');
        btn.classList.remove('btn-primary', 'text-white');
      }
    }

    // Journal
    function checkJournal() {
      const text = document.getElementById('journal-text').value;
      const btn = document.getElementById('save-journal');
      const banner = document.getElementById('draft-banner');
      if (text.length > 10) {
        btn.disabled = false;
        btn.classList.remove('bg-slate-300', 'text-slate-500');
        btn.classList.add('btn-primary', 'text-white');
        banner.classList.remove('hidden');
      } else {
        btn.disabled = true;
        btn.classList.add('bg-slate-300', 'text-slate-500');
        btn.classList.remove('btn-primary', 'text-white');
        banner.classList.add('hidden');
      }
    }

    function saveJournal() {
      showToast('Journal entry saved!');
      setTimeout(() => showScreen('patient-home'), 1000);
    }

    // Sliders
    function updateSlider(type, value) {
      document.getElementById(type + '-value').textContent = value;
      const colors = ['text-red-500', 'text-orange-500', 'text-yellow-500', 'text-teal-500', 'text-green-500'];
      const el = document.getElementById(type + '-value');
      el.className = 'text-2xl font-bold ' + colors[value - 1];
    }

    function submitCheckin() {
      showToast('Check-in submitted!');
      setTimeout(() => showScreen('patient-home'), 1000);
    }

    // Voice recording
    let isRecording = false;
    function toggleRecording() {
      isRecording = !isRecording;
      const btn = document.getElementById('record-btn');
      const recordIcon = document.getElementById('record-icon');
      const stopIcon = document.getElementById('stop-icon');
      const text = document.getElementById('record-text');
      const time = document.getElementById('record-time');
      const uploadBtn = document.getElementById('upload-btn');
      const waveform = document.getElementById('waveform');
      
      if (isRecording) {
        btn.classList.add('recording-active');
        recordIcon.classList.add('hidden');
        stopIcon.classList.remove('hidden');
        text.textContent = 'Recording...';
        time.textContent = '0:00 / 5:00';
        waveform.classList.remove('hidden');
        uploadBtn.classList.add('hidden');
      } else {
        btn.classList.remove('recording-active');
        recordIcon.classList.remove('hidden');
        stopIcon.classList.add('hidden');
        text.textContent = 'Recording complete';
        time.textContent = '1:24 recorded';
        waveform.classList.add('hidden');
        uploadBtn.classList.remove('hidden');
      }
    }

    function uploadVoice() {
      showScreen('patient-voice-progress');
      setTimeout(() => {
        showToast('Voice note uploaded!');
        showScreen('patient-home');
      }, 3000);
    }

    // MFA
    function checkMFA() {
      const inputs = document.querySelectorAll('#clinician-mfa input');
      const allFilled = Array.from(inputs).every(i => i.value.length === 1);
      const btn = document.getElementById('mfa-btn');
      if (allFilled) {
        btn.disabled = false;
        btn.classList.remove('bg-slate-700', 'text-slate-500');
        btn.classList.add('btn-coral', 'text-white');
      }
    }

    function showMFA() {
      showScreen('clinician-mfa');
      setTimeout(() => document.querySelector('#clinician-mfa input').focus(), 300);
    }

    // Demo panel
    function toggleDemoPanel() {
      const panel = document.getElementById('demo-panel');
      const chevron = document.getElementById('demo-chevron');
      panel.classList.toggle('collapsed');
      chevron.style.transform = panel.classList.contains('collapsed') ? 'rotate(180deg)' : 'rotate(0deg)';
    }

    // Demo scenarios
    function triggerT2Alert() {
      document.getElementById('t2-banner').classList.remove('hidden');
      showToast('T2 Safety Alert triggered!');
    }

    function triggerT1Alert() {
      showToast('T1 Alert: Mood trend declining');
    }

    function triggerDegradedMode() {
      document.getElementById('degraded-banner').classList.remove('hidden');
      showToast('Degraded mode activated');
    }

    function resetDemo() {
      document.getElementById('t2-banner').classList.add('hidden');
      document.getElementById('degraded-banner').classList.add('hidden');
      showToast('Demo reset');
    }

    // Toast notifications
    function showToast(message) {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      showScreen('landing');
    });

    // ROI Dashboard Update
    function updateROI(count) {
      document.getElementById('clinician-count').textContent = count;
      const timeSaved = (count * 5.2).toFixed(0);
      const costSaved = (count * 16240).toFixed(0);
      const patients = (count * 24).toFixed(0);
      document.getElementById('time-saved').textContent = timeSaved;
      document.getElementById('cost-saved').textContent = '$' + (costSaved / 1000000).toFixed(2) + 'M';
      document.getElementById('patients-supported').textContent = patients;
    }

    // ROI Dashboard Counter Animation
    function animateCounter(id, target, duration = 2000, prefix = '', suffix = '') {
      const el = document.getElementById(id);
      if (!el) return;
      const start = 0;
      const increment = target / (duration / 16);
      let current = start;
      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = prefix + current.toFixed(1) + suffix;
      }, 16);
    }

    // Story Mode Progress
    let storyStep = 0;
    const storySteps = ['story-step-1', 'story-step-2', 'story-step-3', 'story-step-4', 'story-step-5'];
    function nextStoryStep() {
      if (storyStep < storySteps.length - 1) {
        document.getElementById(storySteps[storyStep]).classList.add('hidden');
        storyStep++;
        document.getElementById(storySteps[storyStep]).classList.remove('hidden');
        updateStoryDots();
      }
    }
    function prevStoryStep() {
      if (storyStep > 0) {
        document.getElementById(storySteps[storyStep]).classList.add('hidden');
        storyStep--;
        document.getElementById(storySteps[storyStep]).classList.remove('hidden');
        updateStoryDots();
      }
    }
    function updateStoryDots() {
      for (let i = 0; i < storySteps.length; i++) {
        const dot = document.getElementById('story-dot-' + (i + 1));
        if (dot) {
          if (i <= storyStep) dot.classList.add('active');
          else dot.classList.remove('active');
        }
      }
    }
    function resetStory() {
      storyStep = 0;
      storySteps.forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) {
          if (i === 0) el.classList.remove('hidden');
          else el.classList.add('hidden');
        }
      });
      updateStoryDots();
    }

    // Comparison Slider
    function initComparisonSlider() {
      const slider = document.getElementById('comparison-slider');
      const handle = document.getElementById('slider-handle');
      const after = document.getElementById('after-layer');
      if (!slider || !handle || !after) return;
      
      let isDragging = false;
      
      handle.addEventListener('mousedown', () => isDragging = true);
      document.addEventListener('mouseup', () => isDragging = false);
      document.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const rect = slider.getBoundingClientRect();
        let x = e.clientX - rect.left;
        x = Math.max(0, Math.min(x, rect.width));
        const percent = (x / rect.width) * 100;
        handle.style.left = percent + '%';
        after.style.clipPath = `inset(0 ${100 - percent}% 0 0)`;
      });
    }

    // AI Confidence Demo
    function analyzeEntry() {
      const entry = document.getElementById('demo-journal-entry').value;
      const results = document.getElementById('ai-analysis-results');
      if (!entry || entry.length < 10) {
        showToast('Please enter at least 10 characters');
        return;
      }
      results.classList.remove('hidden');
      // Animate confidence meter
      setTimeout(() => {
        const meter = document.getElementById('confidence-fill');
        if (meter) meter.style.width = '87%';
      }, 300);
    }
  </script>
</body>
</html>
