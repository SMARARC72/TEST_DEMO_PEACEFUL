<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Behavioral Health AI Companion - VC Demo</title>
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
    * { font-family: 'Inter', sans-serif; }
    .screen { display: none; opacity: 0; transition: opacity 0.3s ease; }
    .screen.active { display: block; opacity: 1; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes slideInRight { from { opacity: 0; transform: translateX(30px); } to { opacity: 1; transform: translateX(0); } }
    @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
    @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    @keyframes recording-pulse { 0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); } 50% { transform: scale(1.05); box-shadow: 0 0 0 20px rgba(239, 68, 68, 0); } }
    @keyframes waveform { 0%, 100% { height: 10px; } 50% { height: 40px; } }
    @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
    .animate-fadeInUp { animation: fadeInUp 0.5s ease forwards; }
    .animate-slideInRight { animation: slideInRight 0.4s ease forwards; }
    .animate-pulse-slow { animation: pulse 2s ease infinite; }
    .animate-float { animation: float 3s ease infinite; }
    .recording-active { animation: recording-pulse 1.5s ease infinite; background: linear-gradient(135deg, #ef4444, #dc2626) !important; }
    .glass { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
    .glass-dark { background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); }
    .gradient-teal { background: linear-gradient(135deg, #0d9488 0%, #14b8a6 50%, #5eead4 100%); }
    .gradient-coral { background: linear-gradient(135deg, #f97316 0%, #fb923c 100%); }
    .gradient-hero { background: linear-gradient(135deg, #0f766e 0%, #0d9488 30%, #14b8a6 70%, #5eead4 100%); }
    .btn-primary { background: linear-gradient(135deg, #0d9488, #14b8a6); transition: all 0.3s ease; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(13, 148, 136, 0.4); }
    .btn-coral { background: linear-gradient(135deg, #f97316, #fb923c); transition: all 0.3s ease; }
    .btn-coral:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(249, 115, 22, 0.4); }
    .card-hover { transition: all 0.3s ease; }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15); }
    .waveform-bar { width: 4px; background: linear-gradient(to top, #0d9488, #14b8a6); border-radius: 2px; animation: waveform 0.5s ease infinite; }
    .toast { position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%) translateY(100px); background: rgba(15, 23, 42, 0.95); color: white; padding: 12px 24px; border-radius: 12px; font-size: 14px; opacity: 0; transition: all 0.3s ease; z-index: 1000; }
    .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
    .demo-panel { position: fixed; top: 20px; right: 20px; width: 280px; z-index: 100; transition: all 0.3s ease; }
    .demo-panel.collapsed { width: 60px; }
    .demo-panel.collapsed .demo-content { display: none; }
    .metric-card { background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(255,255,255,0.7)); border: 1px solid rgba(13, 148, 136, 0.2); }
    .safety-badge { background: linear-gradient(135deg, #fef3c7, #fde68a); border: 1px solid #f59e0b; }
    .t2-alert { background: linear-gradient(135deg, #fee2e2, #fecaca); border-left: 4px solid #dc2626; }
    .t1-alert { background: linear-gradient(135deg, #fef3c7, #fde68a); border-left: 4px solid #f59e0b; }
    .t0-alert { background: linear-gradient(135deg, #dbeafe, #bfdbfe); border-left: 4px solid #2563eb; }
    input[type="range"] { -webkit-appearance: none; height: 8px; border-radius: 4px; background: linear-gradient(to right, #0d9488, #14b8a6); outline: none; }
    input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 24px; height: 24px; border-radius: 50%; background: white; border: 3px solid #0d9488; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,0.2); transition: all 0.2s ease; }
    input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.1); }
    .stagger-1 { animation-delay: 0.1s; }
    .stagger-2 { animation-delay: 0.2s; }
    .stagger-3 { animation-delay: 0.3s; }
    .stagger-4 { animation-delay: 0.4s; }
    /* New VC Demo Enhancements */
    @keyframes countUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes pulse-ring { 0% { transform: scale(0.8); opacity: 1; } 100% { transform: scale(1.3); opacity: 0; } }
    @keyframes slideIn { from { width: 0; } to { width: var(--target-width); } }
    .counter-animate { animation: countUp 0.8s ease forwards; }
    .pulse-ring::before { content: ''; position: absolute; inset: -4px; border-radius: 50%; border: 2px solid currentColor; animation: pulse-ring 1.5s ease-out infinite; }
    .comparison-slider { position: relative; overflow: hidden; }
    .comparison-slider .before, .comparison-slider .after { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
    .comparison-slider .after { clip-path: inset(0 50% 0 0); }
    .comparison-slider .handle { position: absolute; top: 0; bottom: 0; left: 50%; width: 4px; background: white; cursor: ew-resize; z-index: 10; box-shadow: 0 0 10px rgba(0,0,0,0.3); }
    .comparison-slider .handle::after { content: '↔'; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 32px; height: 32px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #0d9488; box-shadow: 0 2px 8px rgba(0,0,0,0.2); }
    .story-mode-container { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .confidence-meter { position: relative; height: 8px; background: #e2e8f0; border-radius: 4px; overflow: hidden; }
    .confidence-fill { position: absolute; top: 0; left: 0; height: 100%; border-radius: 4px; transition: width 1s ease; }
    .confidence-high { background: linear-gradient(90deg, #22c55e, #16a34a); }
    .confidence-medium { background: linear-gradient(90deg, #eab308, #ca8a04); }
    .confidence-low { background: linear-gradient(90deg, #ef4444, #dc2626); }
    .keyword-highlight { background: linear-gradient(120deg, #fef3c7 0%, #fef3c7 100%); padding: 2px 4px; border-radius: 4px; font-weight: 500; }
    .roi-card { background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); border: 1px solid #e2e8f0; border-radius: 16px; padding: 24px; transition: all 0.3s ease; }
    .roi-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
    .metric-large { font-size: 48px; font-weight: 800; background: linear-gradient(135deg, #0d9488, #14b8a6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .scenario-timeline { position: relative; padding-left: 32px; }
    .scenario-timeline::before { content: ''; position: absolute; left: 11px; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, #0d9488, #14b8a6); }
    .timeline-dot { position: absolute; left: 0; width: 24px; height: 24px; background: white; border: 3px solid #0d9488; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .timeline-dot.active { background: #0d9488; }
    .timeline-dot.active::after { content: '✓'; color: white; font-size: 12px; }
    .security-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; background: linear-gradient(135deg, #ecfdf5, #d1fae5); border: 1px solid #10b981; border-radius: 9999px; font-size: 14px; color: #047857; }
    .security-badge svg { width: 16px; height: 16px; }
    .feature-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
    .animated-bar { height: 100%; border-radius: 4px; animation: slideIn 1s ease forwards; }
    @keyframes glow { 0%, 100% { box-shadow: 0 0 5px rgba(13, 148, 136, 0.3); } 50% { box-shadow: 0 0 20px rgba(13, 148, 136, 0.6); } }
    .glow-effect { animation: glow 2s ease infinite; }
  </style>
</head>
<body class="bg-slate-50">
  <!-- Demo Control Panel -->
  <div id="demo-panel" class="demo-panel">
    <div class="glass rounded-xl shadow-2xl overflow-hidden">
      <button onclick="toggleDemoPanel()" class="w-full p-3 bg-gradient-to-r from-teal-600 to-teal-500 text-white flex items-center justify-between">
        <span class="font-semibold text-sm demo-content">Demo Controls</span>
        <svg id="demo-chevron" class="w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="demo-content p-4 space-y-3">
        <div class="text-xs font-semibold text-gray-500 mb-2 uppercase tracking-wide">VC Demo Features</div>
        <button onclick="showScreen('roi-dashboard')" class="w-full py-2 px-3 bg-gradient-to-r from-teal-500 to-teal-600 text-white rounded-lg text-sm font-medium hover:shadow-lg transition-all">ROI Dashboard</button>
        <button onclick="showScreen('story-mode')" class="w-full py-2 px-3 bg-gradient-to-r from-purple-500 to-purple-600 text-white rounded-lg text-sm font-medium hover:shadow-lg transition-all">Story Mode</button>
        <button onclick="showScreen('before-after')" class="w-full py-2 px-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-lg text-sm font-medium hover:shadow-lg transition-all">Before/After</button>
        <div class="border-t pt-3 mt-3">
          <div class="text-xs font-semibold text-gray-500 mb-2 uppercase tracking-wide">Quick Scenarios</div>
          <button onclick="triggerT2Alert()" class="w-full py-2 px-3 bg-red-100 text-red-700 rounded-lg text-sm font-medium hover:bg-red-200 transition-colors">Show T2 Alert</button>
          <button onclick="triggerT1Alert()" class="w-full py-2 px-3 bg-amber-100 text-amber-700 rounded-lg text-sm font-medium hover:bg-amber-200 transition-colors">Show T1 Alert</button>
          <button onclick="triggerDegradedMode()" class="w-full py-2 px-3 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors">Degraded Mode</button>
          <button onclick="resetDemo()" class="w-full py-2 px-3 bg-teal-100 text-teal-700 rounded-lg text-sm font-medium hover:bg-teal-200 transition-colors">Reset Demo</button>
        </div>
        <div class="border-t pt-3 mt-3">
          <div class="text-xs font-semibold text-gray-500 mb-2 uppercase tracking-wide">Safety Features</div>
          <div class="flex items-center justify-between text-sm py-1">
            <span>CSP-001</span>
            <span class="text-teal-600 font-medium flex items-center gap-1"><span class="w-2 h-2 bg-teal-500 rounded-full animate-pulse"></span>Active</span>
          </div>
          <div class="flex items-center justify-between text-sm py-1">
            <span>CSP-002</span>
            <span class="text-teal-600 font-medium flex items-center gap-1"><span class="w-2 h-2 bg-teal-500 rounded-full animate-pulse"></span>Active</span>
          </div>
          <div class="flex items-center justify-between text-sm py-1">
            <span>CSP-003</span>
            <span class="text-teal-600 font-medium flex items-center gap-1"><span class="w-2 h-2 bg-teal-500 rounded-full animate-pulse"></span>Active</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="toast"></div>

  <!-- LANDING PAGE -->
  <div id="landing" class="screen active min-h-screen gradient-hero flex flex-col items-center justify-center p-6 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-20 left-20 w-64 h-64 bg-white rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-20 right-20 w-96 h-96 bg-teal-300 rounded-full blur-3xl animate-float" style="animation-delay: 1s;"></div>
    </div>
    <div class="glass rounded-3xl shadow-2xl p-8 max-w-md w-full text-center relative z-10 animate-fadeInUp">
      <div class="w-24 h-24 gradient-teal rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg animate-pulse-slow">
        <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-slate-800 mb-2">Behavioral Health AI</h1>
      <p class="text-slate-600 mb-6">Clinician-supervised mental health support</p>
      <div class="flex justify-center gap-2 mb-8">
        <span class="safety-badge px-3 py-1 rounded-full text-xs font-semibold text-amber-800">CSP Compliant</span>
        <span class="bg-teal-100 text-teal-800 px-3 py-1 rounded-full text-xs font-semibold">Synthetic Data</span>
      </div>
      <div class="space-y-3">
        <button onclick="showScreen('patient-welcome')" class="w-full btn-primary text-white py-4 rounded-xl font-semibold text-lg">Patient Experience</button>
        <button onclick="showScreen('clinician-login')" class="w-full btn-coral text-white py-4 rounded-xl font-semibold text-lg">Clinician Portal</button>
      </div>
      <div class="mt-6 pt-6 border-t border-slate-200">
        <p class="text-xs font-semibold text-slate-500 mb-3 uppercase tracking-wide">VC Demo Features</p>
        <div class="grid grid-cols-3 gap-2">
          <button onclick="showScreen('story-mode')" class="py-2 px-3 bg-purple-100 text-purple-700 rounded-lg text-sm font-medium hover:bg-purple-200 transition-colors">Story Mode</button>
          <button onclick="showScreen('roi-dashboard')" class="py-2 px-3 bg-teal-100 text-teal-700 rounded-lg text-sm font-medium hover:bg-teal-200 transition-colors">ROI Dashboard</button>
          <button onclick="showScreen('before-after')" class="py-2 px-3 bg-blue-100 text-blue-700 rounded-lg text-sm font-medium hover:bg-blue-200 transition-colors">Before/After</button>
        </div>
      </div>
      <div class="mt-6 pt-6 border-t border-slate-200">
        <p class="text-xs text-slate-500">Prototype v3.0 • VC Demo Ready • No PHI</p>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 text-white text-sm opacity-70">
      Scroll to explore safety features
    </div>
  </div>

  <!-- PATIENT WELCOME -->
  <div id="patient-welcome" class="screen min-h-screen bg-white flex flex-col">
    <div class="flex-1 flex flex-col items-center justify-center p-6 gradient-hero">
      <div class="glass rounded-3xl shadow-2xl p-8 max-w-md w-full text-center animate-fadeInUp">
        <div class="w-20 h-20 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
          <svg class="w-10 h-10 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-slate-800 mb-2">Welcome to Your Companion</h1>
        <p class="text-slate-600 mb-6">AI-powered support between therapy sessions</p>
        <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-4 mb-6">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            <span class="font-semibold text-amber-800">Important</span>
          </div>
          <p class="text-sm text-amber-700">This app complements therapy but is not an emergency service. If in immediate danger, call emergency services.</p>
        </div>
        <button onclick="showScreen('patient-consent')" class="w-full btn-primary text-white py-4 rounded-xl font-semibold">Get Started</button>
      </div>
    </div>
  </div>

  <!-- PATIENT CONSENT -->
  <div id="patient-consent" class="screen min-h-screen bg-slate-50 p-6">
    <div class="max-w-md mx-auto animate-fadeInUp">
      <button onclick="showScreen('patient-welcome')" class="mb-6 flex items-center text-slate-600 hover:text-slate-800">
        <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back
      </button>
      <h1 class="text-2xl font-bold text-slate-800 mb-2">Consent & Privacy</h1>
      <p class="text-slate-600 mb-6">Please review and accept the following</p>
      <div class="space-y-4 mb-8">
        <label class="flex items-start gap-4 p-5 bg-white rounded-xl shadow-sm border-2 border-transparent hover:border-teal-200 cursor-pointer transition-all card-hover">
          <input type="checkbox" class="consent-check mt-1 w-6 h-6 text-teal-600 rounded" onchange="checkConsents()">
          <div>
            <p class="font-semibold text-slate-800">Journaling & Check-ins</p>
            <p class="text-sm text-slate-500">Your entries are visible to your clinician for review</p>
          </div>
        </label>
        <label class="flex items-start gap-4 p-5 bg-white rounded-xl shadow-sm border-2 border-transparent hover:border-teal-200 cursor-pointer transition-all card-hover">
          <input type="checkbox" class="consent-check mt-1 w-6 h-6 text-teal-600 rounded" onchange="checkConsents()">
          <div>
            <p class="font-semibold text-slate-800">Voice Entries</p>
            <p class="text-sm text-slate-500">Recordings are transcribed and stored securely</p>
          </div>
        </label>
        <label class="flex items-start gap-4 p-5 bg-white rounded-xl shadow-sm border-2 border-transparent hover:border-teal-200 cursor-pointer transition-all card-hover">
          <input type="checkbox" class="consent-check mt-1 w-6 h-6 text-teal-600 rounded" onchange="checkConsents()">
          <div>
            <p class="font-semibold text-slate-800">Clinician Review Required</p>
            <p class="text-sm text-slate-500">AI summaries are drafts until approved by your clinician</p>
          </div>
        </label>
        <label class="flex items-start gap-4 p-5 bg-white rounded-xl shadow-sm border-2 border-transparent hover:border-teal-200 cursor-pointer transition-all card-hover">
          <input type="checkbox" class="consent-check mt-1 w-6 h-6 text-teal-600 rounded" onchange="checkConsents()">
          <div>
            <p class="font-semibold text-slate-800">Product Boundaries</p>
            <p class="text-sm text-slate-500">This is not a diagnosis tool or emergency replacement</p>
          </div>
        </label>
      </div>
      <button id="consent-btn" onclick="showScreen('patient-home')" disabled class="w-full py-4 rounded-xl font-semibold bg-slate-300 text-slate-500 transition-all">Continue</button>
    </div>
  </div>

  <!-- PATIENT HOME -->
  <div id="patient-home" class="screen min-h-screen bg-slate-50 pb-24">
    <div id="degraded-banner" class="hidden bg-slate-600 text-white px-4 py-3 text-center">
      <span class="font-semibold">Degraded Mode</span> — Safety workflows prioritized. Limited AI processing.
    </div>
    <div id="t2-banner" class="hidden bg-red-600 text-white px-4 py-3 text-center animate-pulse">
      <span class="font-semibold">Safety Alert Active</span> — Your clinician has been notified
    </div>
    <div class="gradient-teal p-6 pb-12">
      <div class="flex justify-between items-center mb-4">
        <div>
          <p class="text-teal-100 text-sm">Good morning,</p>
          <h1 class="text-2xl font-bold text-white">Alex</h1>
        </div>
        <div class="flex items-center gap-3">
          <div class="bg-white/20 backdrop-blur rounded-full px-3 py-1 flex items-center gap-2">
            <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
            <span class="text-white text-xs">Connected</span>
          </div>
          <button onclick="showScreen('patient-settings')" class="w-10 h-10 bg-white/20 backdrop-blur rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </button>
        </div>
      </div>
      <div class="metric-card rounded-2xl p-4">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-medium text-slate-600">Weekly Mood Trend</span>
          <span class="text-xs text-teal-600 font-semibold">+12% vs last week</span>
        </div>
        <div class="flex items-end gap-1 h-16">
          <div class="flex-1 bg-teal-200 rounded-t" style="height: 40%"></div>
          <div class="flex-1 bg-teal-300 rounded-t" style="height: 55%"></div>
          <div class="flex-1 bg-teal-400 rounded-t" style="height: 45%"></div>
          <div class="flex-1 bg-teal-500 rounded-t" style="height: 70%"></div>
          <div class="flex-1 bg-teal-600 rounded-t" style="height: 85%"></div>
          <div class="flex-1 bg-teal-500 rounded-t" style="height: 75%"></div>
          <div class="flex-1 bg-teal-600 rounded-t" style="height: 90%"></div>
        </div>
        <div class="flex justify-between text-xs text-slate-400 mt-2">
          <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
        </div>
      </div>
    </div>
    <div class="px-4 -mt-6">
      <h2 class="text-sm font-semibold text-slate-500 uppercase mb-3">Today's Actions</h2>
      <div class="space-y-3">
        <button onclick="showScreen('patient-checkin')" class="w-full bg-white p-4 rounded-2xl shadow-sm flex items-center gap-4 text-left card-hover border-l-4 border-teal-500 animate-fadeInUp stagger-1">
          <div class="w-12 h-12 bg-gradient-to-br from-teal-100 to-teal-200 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="flex-1">
            <p class="font-semibold text-slate-800">Daily Check-in</p>
            <p class="text-sm text-slate-500">Track your mood and energy</p>
          </div>
          <span class="text-xs bg-teal-100 text-teal-700 px-2 py-1 rounded-full">2 min</span>
        </button>
        <button onclick="showScreen('patient-journal')" class="w-full bg-white p-4 rounded-2xl shadow-sm flex items-center gap-4 text-left card-hover border-l-4 border-blue-500 animate-fadeInUp stagger-2">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-100 to-blue-200 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <div class="flex-1">
            <p class="font-semibold text-slate-800">Journal Entry</p>
            <p class="text-sm text-slate-500">Write about your day</p>
          </div>
          <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full">Free</span>
        </button>
        <button onclick="showScreen('patient-voice')" class="w-full bg-white p-4 rounded-2xl shadow-sm flex items-center gap-4 text-left card-hover border-l-4 border-purple-500 animate-fadeInUp stagger-3">
          <div class="w-12 h-12 bg-gradient-to-br from-purple-100 to-purple-200 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
          </div>
          <div class="flex-1">
            <p class="font-semibold text-slate-800">Voice Note</p>
            <p class="text-sm text-slate-500">Speak your thoughts</p>
          </div>
          <span class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full">3 min</span>
        </button>
      </div>
    </div>
    <div class="px-4 mt-6">
      <h2 class="text-sm font-semibold text-slate-500 uppercase mb-3">Care Plan Progress</h2>
      <div class="bg-white p-5 rounded-2xl shadow-sm">
        <div class="flex items-center justify-between mb-3">
          <div>
            <p class="font-semibold text-slate-800">CBT Reflection</p>
            <p class="text-sm text-slate-500">Thought reframing exercise</p>
          </div>
          <span class="text-xs bg-amber-100 text-amber-700 px-3 py-1 rounded-full font-medium">In Progress</span>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-2">
          <div class="gradient-teal h-2 rounded-full" style="width: 65%"></div>
        </div>
        <p class="text-xs text-slate-500 mt-2">65% complete — 2 of 3 sessions done</p>
      </div>
    </div>
    <div class="fixed bottom-0 left-0 right-0 glass border-t flex justify-around py-2">
      <button onclick="showScreen('patient-home')" class="flex flex-col items-center p-2 text-teal-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span class="text-xs font-medium">Home</span>
      </button>
      <button onclick="showScreen('patient-journal')" class="flex flex-col items-center p-2 text-slate-400 hover:text-slate-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        <span class="text-xs font-medium">Journal</span>
      </button>
      <button onclick="showScreen('patient-checkin')" class="flex flex-col items-center p-2 text-slate-400 hover:text-slate-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span class="text-xs font-medium">Check-in</span>
      </button>
      <button onclick="showScreen('patient-careplan')" class="flex flex-col items-center p-2 text-slate-400 hover:text-slate-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        <span class="text-xs font-medium">Plan</span>
      </button>
    </div>
  </div>
</body>
</html>

  <!-- PATIENT JOURNAL -->
  <div id="patient-journal" class="screen min-h-screen bg-white flex flex-col">
    <div class="border-b p-4 flex items-center justify-between bg-white">
      <button onclick="showScreen('patient-home')" class="text-slate-600 hover:text-slate-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="font-semibold text-slate-800">New Journal Entry</h1>
      <button onclick="showScreen('patient-history')" class="text-teal-600 font-medium text-sm">History</button>
    </div>
    <div class="flex-1 p-4">
      <p class="text-slate-500 mb-4">What's on your mind today?</p>
      <textarea id="journal-text" placeholder="Write your thoughts here..." class="w-full h-64 p-4 border-2 border-slate-200 rounded-xl resize-none focus:outline-none focus:border-teal-500 focus:ring-2 focus:ring-teal-100 transition-all" oninput="checkJournal()"></textarea>
      <div id="draft-banner" class="mt-4 bg-amber-50 border-2 border-amber-200 rounded-xl p-4 hidden">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <span class="font-semibold text-amber-800">Draft Summary</span>
        </div>
        <p class="text-sm text-amber-700">AI-generated insights require clinician review before being added to your record.</p>
      </div>
    </div>
    <div class="p-4 border-t bg-white">
      <button onclick="saveJournal()" id="save-journal" disabled class="w-full py-4 rounded-xl font-semibold bg-slate-300 text-slate-500 transition-all">Save Entry</button>
    </div>
  </div>

  <!-- PATIENT HISTORY -->
  <div id="patient-history" class="screen min-h-screen bg-slate-50">
    <div class="bg-white border-b p-4 flex items-center sticky top-0 z-10">
      <button onclick="showScreen('patient-home')" class="text-slate-600 mr-4 hover:text-slate-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="font-semibold text-slate-800">Journal History</h1>
    </div>
    <div class="p-4 space-y-4">
      <div class="bg-white p-5 rounded-2xl shadow-sm card-hover animate-fadeInUp">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-slate-500">Today, 9:30 AM</p>
          <span class="text-xs bg-teal-100 text-teal-700 px-2 py-1 rounded-full">Reviewed</span>
        </div>
        <p class="text-slate-800">I had a rough morning but managed to get through it. Looking forward to my session tomorrow.</p>
      </div>
      <div class="bg-white p-5 rounded-2xl shadow-sm card-hover animate-fadeInUp stagger-1">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-slate-500">Yesterday, 8:15 PM</p>
          <span class="text-xs bg-amber-100 text-amber-700 px-2 py-1 rounded-full">Pending Review</span>
        </div>
        <p class="text-slate-800">Practiced the breathing exercises today. They really helped during a stressful meeting.</p>
      </div>
      <div class="bg-white p-5 rounded-2xl shadow-sm card-hover animate-fadeInUp stagger-2">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-slate-500">Feb 22, 7:00 PM</p>
          <span class="text-xs bg-teal-100 text-teal-700 px-2 py-1 rounded-full">Reviewed</span>
        </div>
        <p class="text-slate-800">Feeling more optimistic this week. The new medication seems to be helping.</p>
      </div>
    </div>
  </div>

  <!-- PATIENT CHECK-IN -->
  <div id="patient-checkin" class="screen min-h-screen bg-white flex flex-col">
    <div class="border-b p-4 flex items-center bg-white sticky top-0 z-10">
      <button onclick="showScreen('patient-home')" class="text-slate-600 mr-4 hover:text-slate-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="font-semibold text-slate-800">Daily Check-in</h1>
    </div>
    <div class="flex-1 p-6 space-y-8">
      <div class="animate-fadeInUp">
        <div class="flex items-center justify-between mb-4">
          <label class="font-semibold text-slate-800">How's your mood?</label>
          <span id="mood-value" class="text-2xl font-bold text-teal-600">3</span>
        </div>
        <input type="range" min="1" max="5" value="3" class="w-full" oninput="updateSlider('mood', this.value)">
        <div class="flex justify-between text-sm text-slate-500 mt-2">
          <span>Very Low</span>
          <span>Neutral</span>
          <span>Excellent</span>
        </div>
      </div>
      <div class="animate-fadeInUp stagger-1">
        <div class="flex items-center justify-between mb-4">
          <label class="font-semibold text-slate-800">Stress level</label>
          <span id="stress-value" class="text-2xl font-bold text-coral-600">3</span>
        </div>
        <input type="range" min="1" max="5" value="3" class="w-full" style="background: linear-gradient(to right, #22c55e, #eab308, #ef4444)" oninput="updateSlider('stress', this.value)">
        <div class="flex justify-between text-sm text-slate-500 mt-2">
          <span>Calm</span>
          <span>Moderate</span>
          <span>Overwhelmed</span>
        </div>
      </div>
      <div class="animate-fadeInUp stagger-2">
        <div class="flex items-center justify-between mb-4">
          <label class="font-semibold text-slate-800">Energy level</label>
          <span id="energy-value" class="text-2xl font-bold text-teal-600">3</span>
        </div>
        <input type="range" min="1" max="5" value="3" class="w-full" oninput="updateSlider('energy', this.value)">
        <div class="flex justify-between text-sm text-slate-500 mt-2">
          <span>Exhausted</span>
          <span>Normal</span>
          <span>Energetic</span>
        </div>
      </div>
      <div class="animate-fadeInUp stagger-3">
        <label class="block font-semibold text-slate-800 mb-2">Anything else? (optional)</label>
        <textarea placeholder="Add a note..." class="w-full p-4 border-2 border-slate-200 rounded-xl resize-none h-28 focus:outline-none focus:border-teal-500 focus:ring-2 focus:ring-teal-100 transition-all"></textarea>
      </div>
    </div>
    <div class="p-4 border-t bg-white">
      <button onclick="submitCheckin()" class="w-full btn-primary text-white py-4 rounded-xl font-semibold">Submit Check-in</button>
    </div>
  </div>

  <!-- PATIENT VOICE -->
  <div id="patient-voice" class="screen min-h-screen bg-white flex flex-col">
    <div class="border-b p-4 flex items-center bg-white sticky top-0 z-10">
      <button onclick="showScreen('patient-home')" class="text-slate-600 mr-4 hover:text-slate-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="font-semibold text-slate-800">Voice Note</h1>
    </div>
    <div class="flex-1 flex flex-col items-center justify-center p-6">
      <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-4 mb-8 max-w-sm">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="font-semibold text-amber-800">Privacy Notice</span>
        </div>
        <p class="text-sm text-amber-700">Your voice entry will be transcribed and visible to your clinician.</p>
      </div>
      <div id="waveform" class="flex items-center gap-1 h-16 mb-8 hidden">
        <div class="waveform-bar" style="animation-delay: 0s"></div>
        <div class="waveform-bar" style="animation-delay: 0.1s"></div>
        <div class="waveform-bar" style="animation-delay: 0.2s"></div>
        <div class="waveform-bar" style="animation-delay: 0.3s"></div>
        <div class="waveform-bar" style="animation-delay: 0.4s"></div>
        <div class="waveform-bar" style="animation-delay: 0.5s"></div>
        <div class="waveform-bar" style="animation-delay: 0.6s"></div>
        <div class="waveform-bar" style="animation-delay: 0.7s"></div>
        <div class="waveform-bar" style="animation-delay: 0.8s"></div>
        <div class="waveform-bar" style="animation-delay: 0.9s"></div>
      </div>
      <button onclick="toggleRecording()" id="record-btn" class="w-28 h-28 rounded-full flex items-center justify-center mb-6 btn-primary shadow-lg transition-all">
        <svg id="record-icon" class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
        </svg>
        <svg id="stop-icon" class="w-12 h-12 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
          <rect x="6" y="6" width="12" height="12" rx="2"/>
        </svg>
      </button>
      <p class="text-lg font-semibold text-slate-800 mb-2" id="record-text">Tap to record</p>
      <p class="text-slate-500" id="record-time">Up to 5 minutes</p>
    </div>
    <div id="upload-btn" class="p-4 border-t bg-white hidden">
      <button onclick="uploadVoice()" class="w-full btn-primary text-white py-4 rounded-xl font-semibold">Done & Upload</button>
    </div>
  </div>

  <!-- PATIENT VOICE PROGRESS -->
  <div id="patient-voice-progress" class="screen min-h-screen bg-white flex flex-col">
    <div class="border-b p-4 flex items-center bg-white sticky top-0 z-10">
      <button onclick="showScreen('patient-home')" class="text-slate-600 mr-4 hover:text-slate-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <h1 class="font-semibold text-slate-800">Processing</h1>
    </div>
    <div class="flex-1 flex flex-col items-center justify-center p-6">
      <div class="w-24 h-24 rounded-full border-4 border-teal-200 border-t-teal-600 animate-spin mb-6"></div>
      <p class="text-xl font-semibold text-slate-800 mb-2">Transcribing your voice note...</p>
      <p class="text-slate-500 text-center">This may take a moment. You'll be notified when it's ready.</p>
      <div class="mt-8 bg-amber-50 border-2 border-amber-200 rounded-xl p-4 max-w-sm">
        <p class="text-sm text-amber-700 text-center">Your clinician will review the transcription before it's added to your record.</p>
      </div>
    </div>
  </div>

  <!-- PATIENT CARE PLAN -->
  <div id="patient-careplan" class="screen min-h-screen bg-slate-50 pb-24">
