{
  "name": "prototype-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "check:artifacts": "node scripts/check-merge-artifacts.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:circular": "node scripts/check-circular-deps.mjs",
    "check:synthetic": "node scripts/check-synthetic-data.mjs",
    "verify:no-conflicts": "node scripts/verify-demo-stability.mjs",
    "build": "npm run check:artifacts && tsc -b && vite build",
    "postbuild": "npm run check:bundle",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test tests/smoke.spec.mjs",
    "test:e2e": "playwright test tests/e2e-*.spec.mjs",
    "quality": "npm run lint && npm run check:circular && npm run check:synthetic && npm test && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "ky": "^1.14.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-router": "^7.13.1",
    "recharts": "^3.7.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
